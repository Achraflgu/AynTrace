# PostgreSQL Connection
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/geotrack

# Server Config
PORT=3001
NODE_ENV=development

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:8080

# Tracker URL - Set this to your public tunnel URL if using Cloudflare
# Defaults to http://localhost:3001 when not set
# TRACKER_URL=https://your-tunnel.trycloudflare.com

# n8n Integration (optional)
# N8N_CHAT_WEBHOOK=http://localhost:5678/webhook/geotrack-chat
# N8N_ORDER_WEBHOOK=http://localhost:5678/webhook/geotrack-order

# Ollama AI (optional)
# OLLAMA_URL=http://localhost:11434
# OLLAMA_MODEL=gemma3:1b
